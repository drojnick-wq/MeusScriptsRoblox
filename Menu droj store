--// UTILITÁRIOS
local function WorldToScreen(position)
    local screenPoint, onScreen = Camera:WorldToViewportPoint(position)
    return Vector2.new(screenPoint.X, screenPoint.Y), onScreen
end

local function GetDistance(pos1, pos2)
    return (pos1 - pos2).Magnitude
end

local function GetTargetPart(player)
    local char = player.Character
    if not char then return nil end
    if aimTarget == "Cabeça" then
        return char:FindFirstChild("Head")
    elseif aimTarget == "Peito" then
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    end
    return char:FindFirstChild("Head")
end

local function GetClosestPlayerToCrosshair()
    local closestPlayer = nil
    local closestDistance = fovSize
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health <= 0 then continue end
            local targetPart = GetTargetPart(player)
            if targetPart then
                local partPos, onScreen = WorldToScreen(targetPart.Position)
                if onScreen then
                    local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local distance = (partPos - mousePos).Magnitude
                    if distance < closestDistance then
                        closestDistance = distance
                        closestPlayer = player
                    end
                end
            end
        end
    end
    return closestPlayer
end

--// AIMBOT LOOP
RunService.RenderStepped:Connect(function()
    if aimbotEnabled then
        local target = GetClosestPlayerToCrosshair()
        if target then
            local targetPart = GetTargetPart(target)
            if targetPart then
                local targetPos = targetPart.Position
                if aimbotLevel == 10 then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                else
                    local smoothness = 1 - (aimbotLevel / 10)
                    if smoothness < 0.05 then smoothness = 0.05 end
                    local currentPos = Camera.CFrame.Position
                    local lookVector = (targetPos - currentPos).Unit
                    local newCFrame = CFrame.new(currentPos, currentPos + lookVector)
                    Camera.CFrame = Camera.CFrame:Lerp(newCFrame, 1 - smoothness)
                end
            end
        end
    end
end)

--// CRIAÇÃO DAS ESPS
local function CreateHighlightForPlayer(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    local oldHL = char:FindFirstChild("ESP_Highlight")
    if oldHL then oldHL:Destroy() end
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = char
    highlight.FillColor = Color3.fromRGB(170, 0, 255)
    highlight.OutlineColor = Color3.fromRGB(170, 0, 255)
    highlight.FillTransparency = 0.85
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = char
    return highlight
end

local function CreateESPForPlayer(player)
    if player == LocalPlayer then return end
    if espObjects[player] then return end
    local drawings = {
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        Tracer = Drawing.new("Line"),
    }
    drawings.Name.Size = 16; drawings.Name.Center = true; drawings.Name.Outline = true; drawings.Name.Color = Color3.fromRGB(170, 0, 255); drawings.Name.Visible = false
    drawings.Distance.Size = 14; drawings.Distance.Center = true; drawings.Distance.Outline = true; drawings.Distance.Color = Color3.fromRGB(170, 0, 255); drawings.Distance.Visible = false
    drawings.Tracer.Thickness = 1; drawings.Tracer.Color = Color3.fromRGB(170, 0, 255); drawings.Tracer.Visible = false
    espObjects[player] = drawings
end

--// LOOP DE ATUALIZAÇÃO DAS ESPs E FOV
local fovCircle = Drawing.new("Circle")
fovCircle.Radius = fovSize
fovCircle.Color = Color3.fromRGB(170, 0, 255)
fovCircle.Thickness = 2
fovCircle.Filled = false
fovCircle.Visible = false

RunService.RenderStepped:Connect(function()
    if aimbotEnabled then
        fovCircle.Visible = true
        fovCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        fovCircle.Radius = fovSize
    else
        fovCircle.Visible = false
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if not espObjects[player] then CreateESPForPlayer(player) end
            local drawings = espObjects[player]
            if not drawings then continue end
            local char = player.Character
            if not char or (char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").Health <= 0) then
                drawings.Name.Visible = false; drawings.Distance.Visible = false; drawings.Tracer.Visible = false
                if char then
                    local hl = char:FindFirstChild("ESP_Highlight")
                    if hl then hl:Destroy() end
                end
                continue
            end
            if espEnabled.WallChams then
                if char then
                    local hl = char:FindFirstChild("ESP_Highlight")
                    if not hl then CreateHighlightForPlayer(player) end
                end
            else
                if char then
                    local hl = char:FindFirstChild("ESP_Highlight")
                    if hl then hl:Destroy() end
                end
            end
            local root = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            if not root or not head then continue end
            local headScreen, onScreen = WorldToScreen(head.Position)
            local rootScreen, _ = WorldToScreen(root.Position)
            local dist = GetDistance(LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart").Position or root.Position, root.Position)
            if espEnabled.Tracer and onScreen then
                local bottomScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                drawings.Tracer.From = bottomScreen; drawings.Tracer.To = headScreen; drawings.Tracer.Visible = true
            else
                drawings.Tracer.Visible = false
            end
            if espEnabled.Name and onScreen then
                drawings.Name.Text = player.Name
                drawings.Name.Position = Vector2.new(headScreen.X, headScreen.Y - 40); drawings.Name.Visible = true
            else
                drawings.Name.Visible = false
            end
            if espEnabled.Distance and onScreen then
                drawings.Distance.Text = string.format("%.1f m", dist)
                drawings.Distance.Position = Vector2.new(rootScreen.X, rootScreen.Y + 20); drawings.Distance.Visible = true
            else
                drawings.Distance.Visible = false
            end
        end
    end
end)

