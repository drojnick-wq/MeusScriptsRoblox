SpeedCorner.CornerRadius = UDim.new(0, 4)

local VflyButton = Instance.new("TextButton", MainFrame)
VflyButton.Size, VflyButton.Position = UDim2.new(0, 130, 0, 26), UDim2.new(0.5, -65, 0, 72)
VflyButton.Text, VflyButton.BackgroundColor3, VflyButton.TextColor3 = "VFLY: OFF", DROJ_PURPLE, Color3.fromRGB(255, 255, 255)
local VflyCorner = Instance.new("UICorner", VflyButton)
VflyCorner.CornerRadius = UDim.new(0, 5)

ToggleButton.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)
SpeedInput.FocusLost:Connect(function() FlySpeed = tonumber(SpeedInput.Text) or 60 end)

-- CONTROLES ROXOS
local ControlsFrame = Instance.new("Frame", ScreenGui)
ControlsFrame.Size, ControlsFrame.BackgroundTransparency, ControlsFrame.Visible = UDim2.new(1, 0, 1, 0), 1, false

local function createBtn(n, t, p)
    local b = Instance.new("TextButton", ControlsFrame)
    b.Text, b.Position, b.Size = t, p, UDim2.new(0, 90, 0, 70)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 30); b.TextColor3 = DROJ_PURPLE; b.Font = Enum.Font.GothamBold
    local btnCorner = Instance.new("UICorner", b)
    btnCorner.CornerRadius = UDim.new(0, 12)
    
    local btnStroke = Instance.new("UIStroke", b)
    btnStroke.Color = DROJ_PURPLE
    btnStroke.Thickness = 2
    
    b.MouseButton1Down:Connect(function() inputs[n] = true end)
    b.MouseButton1Up:Connect(function() inputs[n] = false end)
end
createBtn("Gas", "GÁS", UDim2.new(0.8, 0, 0.65, 0))
createBtn("Re", "RÉ", UDim2.new(0.7, 0, 0.72, 0))

VflyButton.MouseButton1Click:Connect(function()
    VflyEnabled = not VflyEnabled
    ControlsFrame.Visible = VflyEnabled
    VflyButton.Text = VflyEnabled and "VFLY: ON" or "VFLY: OFF"
    if VflyEnabled then
        local seat = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") and LocalPlayer.Character.Humanoid.SeatPart
        if seat then
            CurrentVehicle = seat
            
            -- Cria a força de velocidade linear
            BodyVel = Instance.new("BodyVelocity")
            BodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            BodyVel.Parent = seat
            
            -- Cria o estabilizador de mira
            BodyGyro = Instance.new("BodyGyro")
            BodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            BodyGyro.P = 500000 -- Força aumentada para ignorar a rotação nativa do carro
            BodyGyro.Parent = seat
        end
    else
        if BodyVel then BodyVel:Destroy() end
        if BodyGyro then BodyGyro:Destroy() end
        CurrentVehicle = nil
    end
end)

-- LOOP TOTALMENTE CORRIGIDO PARA ALINHAMENTO DA CÂMERA
RunService.RenderStepped:Connect(function()
    if VflyEnabled and CurrentVehicle and CurrentVehicle.Parent then
        -- Cancela os giros provocados pelo motor e físicas do jogo
        CurrentVehicle.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        
        -- Alinha rigidamente a rotação do carro com a direção da câmera em 3D
        BodyGyro.CFrame = Camera.CFrame
        
        -- Aplica os movimentos baseados para onde a câmera está apontada
        if inputs.Gas then
            BodyVel.Velocity = Camera.CFrame.LookVector * FlySpeed
        elseif inputs.Re then
            BodyVel.Velocity = Camera.CFrame.LookVector * -FlySpeed
        else
            -- Garante o carro totalmente travado no ar ao soltar os botões
            BodyVel.Velocity = Vector3.new(0, 0, 0)
        end
    end
end)

