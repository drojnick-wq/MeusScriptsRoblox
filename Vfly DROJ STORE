local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local DROJ_PURPLE = Color3.fromRGB(130, 0, 255)
local DARK_BG = Color3.fromRGB(12, 12, 16)

if game.CoreGui:FindFirstChild("DrojStoreVFly") then 
    game.CoreGui.DrojStoreVFly:Destroy() 
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "DrojStoreVFly"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = game.CoreGui

local VflyEnabled, FlySpeed, CurrentVehicle, BodyVel, BodyGyro = false, 60, nil, nil, nil
local inputs = { Gas = false, Re = false }

local function MakeDraggable(f)
    f.Active = true; f.Draggable = true 
end

-- BOTÃO D ROXO
