--// ESP Menu Script - Droj Store (Rodapé Atualizado)
--// Features: Wall Highlight (Borda), Name, Distance (Feet), Tracer
--// Theme: Dark/Purple, Minimized by Default

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

if not Drawing then
    warn("Drawing API not supported! Proceeding with Highlight.")
end

--// Configurações
local ESP_COLOR = Color3.fromRGB(170, 0, 255) -- Roxo
local MENU_BG_COLOR = Color3.fromRGB(20, 20, 20)

--// Estados (Desativados por padrão)
local espEnabled = {
    WallChams = false,
    Name = false,
    Distance = false,
    Tracer = false,
}
local espObjects = {}

--// Utilitários
local function WorldToScreen(position)
    local screenPoint, onScreen = Camera:WorldToViewportPoint(position)
    return Vector2.new(screenPoint.X, screenPoint.Y), onScreen
end

local function GetDistance(pos1, pos2)
    return (pos1 - pos2).Magnitude
end

--// Criar Highlight (Chams Roxo - COMO BORDA)
local function CreateHighlightForPlayer(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end

    local oldHL = char:FindFirstChild("ESP_Highlight")
    if oldHL then oldHL:Destroy() end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = char
    highlight.FillColor = ESP_COLOR
    highlight.OutlineColor = ESP_COLOR
    highlight.FillTransparency = 0.85 
    highlight.OutlineTransparency = 0
    highlight.Parent = char
    
    return highlight
end

--// Criar ESP de Texto
local function CreateESPForPlayer(player)
    if player == LocalPlayer then return end
    if espObjects[player] then return end

    local drawings = {
        Name = nil,
        Distance = nil,
        Tracer = nil,
    }

    local nameText = Drawing.new("Text")
    nameText.Size = 16
    nameText.Center = true
    nameText.Outline = true
    nameText.Color = ESP_COLOR
    nameText.Visible = false
    drawings.Name = nameText

    local distText = Drawing.new("Text")
    distText.Size = 14
    distText.Center = true
    distText.Outline = true
    distText.Color = ESP_COLOR
    distText.Visible = false
    drawings.Distance = distText

    local tracer = Drawing.new("Line")
    tracer.Thickness = 1
    tracer.Color = ESP_COLOR
    tracer.Visible = false
    drawings.Tracer = tracer

    espObjects[player] = drawings
end

--// Loop de Atualização
local function UpdateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if not espObjects[player] then CreateESPForPlayer(player) end
            
            local drawings = espObjects[player]
            if not drawings then continue end

            local char = player.Character
            
            if espEnabled.WallChams then
                if char then
                    local hl = char:FindFirstChild("ESP_Highlight")
                    if not hl then CreateHighlightForPlayer(player) end
                end
            else
                if char then
                    local hl = char:FindFirstChild("ESP_Highlight")
                    if hl then hl:Destroy() end
                end
            end

            if not char then
                drawings.Name.Visible = false
                drawings.Distance.Visible = false
                drawings.Tracer.Visible = false
                continue
            end

            local root = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            if not root or not head then continue end

            local headScreen, onScreen = WorldToScreen(head.Position)
            local rootScreen, _ = WorldToScreen(root.Position)
            local dist = GetDistance(LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart").Position or root.Position, root.Position)

            --// Name (Acima da cabeça)
            if espEnabled.Name and onScreen then
                drawings.Name.Text = player.Name
                drawings.Name.Position = Vector2.new(headScreen.X, headScreen.Y - 40)
                drawings.Name.Visible = true
            else
                drawings.Name.Visible = false
            end

            --// Distance (No chão, abaixo dos pés)
            if espEnabled.Distance and onScreen then
                drawings.Distance.Text = string.format("%.1f m", dist)
                drawings.Distance.Position = Vector2.new(rootScreen.X, rootScreen.Y + 20)
                drawings.Distance.Visible = true
            else
                drawings.Distance.Visible = false
            end

            --// Tracer
            if espEnabled.Tracer and onScreen then
                local bottomScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                drawings.Tracer.From = bottomScreen
                drawings.Tracer.To = headScreen
                drawings.Tracer.Visible = true
            else
                drawings.Tracer.Visible = false
            end
        end
    end
end

RunService.RenderStepped:Connect(UpdateESP)

