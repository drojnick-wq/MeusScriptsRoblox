    if input == dragInputBtn and dragBtn then
        local delta = input.Position - dragStartBtn
        btnOpen.Position = UDim2.new(startPosBtn.X.Scale, startPosBtn.X.Offset + delta.X, startPosBtn.Y.Scale, startPosBtn.Y.Offset + delta.Y)
    end
end)

